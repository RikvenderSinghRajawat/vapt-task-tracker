{
  "name": "ekavach-api",
  "version": "2.0.0",
  "description": "eKavach VAPT Vulnerability Assessment & Penetration Testing Tracker",
  "main": "src/app.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "seed": "node scripts/seed.js",
    "lint": "eslint src --ext .js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "sast": "npm audit && npx eslint src/ --ignore-pattern node_modules"
  },
  "keywords": [
    "vapt",
    "security",
    "vulnerability",
    "tracker"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.10",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "puppeteer": "^24.15.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.6.1",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-security": "^4.0.0",
    "jest": "^29.7.0",
    "mockingoose": "^2.16.0",
    "node-mocks-http": "^1.17.2",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "type": "commonjs"
}
