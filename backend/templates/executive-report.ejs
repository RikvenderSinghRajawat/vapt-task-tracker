<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= reportTitle %></title>
<style><%- css %></style>
<style>
  .page-break { page-break-before: always; }
  @media print { .page-break { page-break-before: always; } }
</style>
</head>
<body>

<!-- ═══════════ COVER PAGE ═══════════ -->
<div class="cover-page page">
  <div class="cover-header">
    <div class="cover-label">Security Assessment Report</div>
    <h1 class="cover-title"><%= project.name %></h1>
    <div class="cover-subtitle">Executive VAPT Summary &mdash; <%= project.assessmentType %></div>
  </div>

  <div class="cover-meta">
    <div class="cover-meta-item">
      <span class="cover-meta-label">Project Code</span>
      <span class="cover-meta-value"><%= project.code %></span>
    </div>
    <div class="cover-meta-item">
      <span class="cover-meta-label">Organization</span>
      <span class="cover-meta-value"><%= project.organization %></span>
    </div>
    <div class="cover-meta-item">
      <span class="cover-meta-label">Assessment Period</span>
      <span class="cover-meta-value"><%= new Date(project.startDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %> &ndash; <%= project.endDate ? new Date(project.endDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : 'Ongoing' %></span>
    </div>
    <div class="cover-meta-item">
      <span class="cover-meta-label">Project Status</span>
      <span class="cover-meta-value" style="text-transform:capitalize"><%= project.status %></span>
    </div>
    <div class="cover-meta-item">
      <span class="cover-meta-label">Total Findings</span>
      <span class="cover-meta-value"><%= summary.total %></span>
    </div>
    <div class="cover-meta-item">
      <span class="cover-meta-label">Overall Risk Level</span>
      <span class="cover-meta-value"><span class="risk-badge <%= riskLevel.toLowerCase() %>"><%= riskLevel %></span></span>
    </div>
    <div class="cover-meta-item">
      <span class="cover-meta-label">Report Generated</span>
      <span class="cover-meta-value"><%= new Date(generatedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
    </div>
    <div class="cover-meta-item">
      <span class="cover-meta-label">Generated By</span>
      <span class="cover-meta-value"><%= generatedBy %></span>
    </div>
  </div>

  <div class="cover-footer">
    <span>CONFIDENTIAL</span>
    <span>&copy; <%= new Date().getFullYear() %> &mdash; For authorized recipients only</span>
  </div>
</div>

<div class="page">

<!-- ═══════════ 1. EXECUTIVE SUMMARY ═══════════ -->
<div class="section">
  <h2 class="section-title"><span class="section-number">1</span> Executive Summary</h2>
  <div class="card">
    <p style="font-size:14px;color:var(--text-muted);margin:0 0 16px 0;">
      This report provides a comprehensive security assessment of <strong><%= project.name %></strong>
      (<%= project.code %>). A total of <strong><%= summary.total %></strong> security findings were identified
      across the assessment, with <strong><%= summary.critical %></strong> critical,
      <strong><%= summary.high %></strong> high,
      <strong><%= summary.medium %></strong> medium,
      <strong><%= summary.low %></strong> low, and
      <strong><%= summary.info %></strong> informational severity items.
    </p>
    <p style="font-size:14px;color:var(--text-muted);margin:0;">
      The overall risk score is <strong><%= overallRiskScore %>%</strong>, classified as
      <strong style="color:<%= riskLevel === 'Critical' ? '#DC2626' : riskLevel === 'High' ? '#EA580C' : riskLevel === 'Medium' ? '#D97706' : '#16A34A' %>"><%= riskLevel %></strong>.
      <%- riskLevel === 'Critical' || riskLevel === 'High'
        ? 'Immediate remediation is strongly recommended for all critical and high severity findings.'
        : 'Continued monitoring and remediation of identified issues is recommended.'
      %>
    </p>
  </div>
</div>

<!-- ═══════════ 2. FINDINGS OVERVIEW ═══════════ -->
<div class="section page-break">
  <h2 class="section-title"><span class="section-number">2</span> Findings Overview</h2>

  <!-- Hero stats row -->
  <div class="hero-stats">
    <div class="hero-stat total">
      <span class="hero-stat-value"><%= summary.total %></span>
      <span class="hero-stat-label">Total</span>
    </div>
    <div class="hero-stat critical">
      <span class="hero-stat-value"><%= summary.critical %></span>
      <span class="hero-stat-label">Critical</span>
    </div>
    <div class="hero-stat high">
      <span class="hero-stat-value"><%= summary.high %></span>
      <span class="hero-stat-label">High</span>
    </div>
    <div class="hero-stat medium">
      <span class="hero-stat-value"><%= summary.medium %></span>
      <span class="hero-stat-label">Medium</span>
    </div>
    <div class="hero-stat low">
      <span class="hero-stat-value"><%= summary.low %></span>
      <span class="hero-stat-label">Low</span>
    </div>
    <div class="hero-stat info">
      <span class="hero-stat-value"><%= summary.info %></span>
      <span class="hero-stat-label">Info</span>
    </div>
  </div>

  <!-- Severity bar chart -->
  <div class="card">
    <div class="chart-title">Severity Distribution</div>
    <div class="bar-chart">
      <% severityChart.forEach(function(item) { %>
      <div class="bar-row">
        <div class="bar-label"><%= item.severity %></div>
        <div class="bar-track">
          <div class="bar-fill <%= item.severity %>" style="width:<%= Math.max(item.pct, item.count > 0 ? 3 : 0) %>%">
            <% if (item.count > 0) { %><span class="bar-count"><%= item.count %></span><% } %>
          </div>
        </div>
        <div class="bar-pct"><%= item.pct %>%</div>
      </div>
      <% }); %>
    </div>
  </div>

  <!-- Status distribution -->
  <div class="card">
    <div class="chart-title">Status Distribution</div>
    <div class="status-row">
      <div class="status-chip open"><span class="status-chip-count"><%= summary.open %></span> Open</div>
      <div class="status-chip in_progress"><span class="status-chip-count"><%= summary.inProgress %></span> In Progress</div>
      <div class="status-chip resolved"><span class="status-chip-count"><%= summary.resolved %></span> Resolved / Closed</div>
      <div class="status-chip accepted_risk"><span class="status-chip-count"><%= summary.acceptedRisk %></span> Accepted Risk</div>
    </div>
    <div class="bar-chart" style="margin-top:12px">
      <% statusChart.forEach(function(item) { %>
      <div class="bar-row">
        <div class="bar-label" style="width:120px;text-transform:capitalize"><%= item.group %></div>
        <div class="bar-track">
          <div class="bar-fill" style="width:<%= Math.max(item.pct, item.count > 0 ? 3 : 0) %>%;background:linear-gradient(90deg,<%= item.group === 'open' ? '#3B82F6' : item.group === 'in_progress' ? '#F59E0B' : item.group === 'resolved' ? '#22C55E' : item.group === 'accepted_risk' ? '#8B5CF6' : '#94A3B8' %>,<%= item.group === 'open' ? '#60A5FA' : item.group === 'in_progress' ? '#FBBF24' : item.group === 'resolved' ? '#4ADE80' : item.group === 'accepted_risk' ? '#A78BFA' : '#CBD5E1' %>)">
            <% if (item.count > 0) { %><span class="bar-count"><%= item.count %></span><% } %>
          </div>
        </div>
        <div class="bar-pct"><%= item.pct %>%</div>
      </div>
      <% }); %>
    </div>
  </div>
</div>

<!-- ═══════════ 3. TOP FINDINGS ═══════════ -->
<% if (topFindings.length > 0) { %>
<div class="section page-break">
  <h2 class="section-title"><span class="section-number">3</span> Top Findings (Critical &amp; High)</h2>
  <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">
    The following <%= topFindings.length %> critical and high severity findings require immediate attention:
  </p>
  <table class="findings-table">
    <thead>
      <tr>
        <th style="width:40px">#</th>
        <th>Finding</th>
        <th style="width:90px">Severity</th>
        <th style="width:100px">Status</th>
      </tr>
    </thead>
    <tbody>
      <% topFindings.forEach(function(f, i) { %>
      <tr>
        <td style="text-align:center;font-weight:600;color:var(--text-muted)"><%= i + 1 %></td>
        <td>
          <strong style="font-size:13px"><%= f.title %></strong>
          <% if (f.category) { %><br><span style="font-size:11px;color:var(--text-muted)"><%= f.category %></span><% } %>
        </td>
        <td class="severity-cell"><span class="severity-badge <%= f.severity %>"><%= f.severity %></span></td>
        <td><span class="status-badge <%= f.status.replace(/_/g, '').toLowerCase() %>"><%= f.status.replace(/_/g, ' ') %></span></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<% } %>

<!-- ═══════════ 4. DETAILED FINDINGS ═══════════ -->
<% if (findings.length > 0) { %>
<div class="section page-break">
  <h2 class="section-title"><span class="section-number">4</span> Detailed Findings</h2>
  <% findings.forEach(function(f) { %>
  <div class="finding-card <%= f.severity %>">
    <div class="finding-card-header">
      <h3 class="finding-card-title"><%= f.title %></h3>
      <span class="severity-badge <%= f.severity %>"><%= f.severity %></span>
    </div>
    <div class="finding-card-meta">
      <% if (f.cvssScore !== undefined && f.cvssScore !== null) { %><span style="font-size:12px;color:var(--text-muted)">CVSS: <strong><%= f.cvssScore %></strong></span><% } %>
      <% if (f.category) { %><span style="font-size:12px;color:var(--text-muted)">Category: <strong><%= f.category %></strong></span><% } %>
      <span style="font-size:12px;color:var(--text-muted)">Status: <span class="status-badge <%= f.status.replace(/_/g, '').toLowerCase() %>"><%= f.status.replace(/_/g, ' ') %></span></span>
      <% if (f.assignee && f.assignee.name) { %><span style="font-size:12px;color:var(--text-muted)">Assignee: <strong><%= f.assignee.name %></strong></span><% } %>
    </div>
    <% if (f.description) { %>
    <p class="finding-card-desc"><%= f.description.substring(0, 300) %><%= f.description.length > 300 ? '...' : '' %></p>
    <% } %>
    <% if (f.remediation) { %>
    <div class="finding-card-remediation">
      <strong>Remediation:</strong> <%= f.remediation.substring(0, 200) %><%= f.remediation.length > 200 ? '...' : '' %>
    </div>
    <% } %>
    <% if (f.location) { %>
    <div style="margin-top:8px;font-size:11px;color:var(--text-light);font-family:monospace">
      Location: <%= f.location %>
    </div>
    <% } %>
  </div>
  <% }); %>
</div>
<% } %>

<!-- ═══════════ 5. RECOMMENDATIONS ═══════════ -->
<div class="section page-break">
  <h2 class="section-title"><span class="section-number">5</span> Recommendations</h2>
  <div class="card">
    <% if (summary.critical > 0) { %>
    <div class="recommendation-item">
      <strong>Address Critical Vulnerabilities Immediately:</strong> <%= summary.critical %> critical severity findings require urgent remediation. These vulnerabilities pose the highest risk to the application and should be prioritized for fix within the shortest possible SLA window.
    </div>
    <% } %>
    <% if (summary.high > 0) { %>
    <div class="recommendation-item">
      <strong>Prioritize High Severity Findings:</strong> <%= summary.high %> high severity findings should be addressed in the next remediation cycle. These issues could lead to significant security breaches if left unaddressed.
    </div>
    <% } %>
    <% if (summary.medium > 0) { %>
    <div class="recommendation-item">
      <strong>Plan Medium Severity Remediation:</strong> <%= summary.medium %> medium severity findings should be incorporated into the regular development and patch management process.
    </div>
    <% } %>
    <div class="recommendation-item">
      <strong>Continuous Monitoring:</strong> Implement ongoing security monitoring, regular vulnerability scanning, and periodic penetration testing to maintain a strong security posture.
    </div>
    <div class="recommendation-item">
      <strong>Security Awareness:</strong> Ensure development and operations teams receive regular security training covering secure coding practices, threat modeling, and incident response.
    </div>
    <% if (summary.acceptedRisk > 0) { %>
    <div class="recommendation-item">
      <strong>Review Accepted Risks:</strong> <%= summary.acceptedRisk %> findings are marked as accepted risk. These should be periodically reviewed and formally documented with business owner sign-off.
    </div>
    <% } %>
    <div class="recommendation-item">
      <strong>Re-Assessment:</strong> Schedule a re-assessment after remediation efforts to verify fix effectiveness and identify any new vulnerabilities introduced during the fix process.
    </div>
  </div>
</div>

<!-- ═══════════ FOOTER ═══════════ -->
<div class="footer no-print">
  <p><strong><%= reportTitle %></strong></p>
  <p>Generated on <%= new Date(generatedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %> &mdash; Classification: CONFIDENTIAL</p>
  <p>&copy; <%= new Date().getFullYear() %>. All rights reserved.</p>
</div>

</div><!-- .page -->

</body>
</html>
