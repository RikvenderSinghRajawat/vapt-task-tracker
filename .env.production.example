# ============================================================
# eKavach VAPT Tracker — Production Environment
# ============================================================
# Copy to backend/.env and configure before starting.
# DO NOT commit .env to version control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
API_VERSION=v1

# ── Database ────────────────────────────────────────────────
# If MongoDB auth is enabled (via setup.sh):
# MONGO_URI=mongodb://root:YOUR_MONGO_PASSWORD@127.0.0.1:27017/vapt_tracker?authSource=admin
MONGO_URI=mongodb://127.0.0.1:27017/vapt_tracker
MONGO_DB_NAME=vapt_tracker
DB_MAX_POOL=10
DB_MAX_RETRIES=10
DB_RETRY_DELAY_MS=3000

# ── JWT & Auth ──────────────────────────────────────────────
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-random-64-char-hex-string
REFRESH_TOKEN_SECRET=change-this-to-another-random-64-char-hex-string
JWT_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ── Storage ─────────────────────────────────────────────────
STORAGE_ROOT=
MAX_FILE_SIZE=52428800

# ── CORS / Frontend URLs ───────────────────────────────────
# In production via nginx, frontend & API are served from same origin,
# so relative /api path is used and these are mainly for WebSocket fallback.
# THE API IS PERMISSIVE FOR INTERNAL USE - all origins allowed.
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=

# ── Super Admin (first-run seed) ────────────────────────────
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=CHANGE_SUPER_ADMIN_PASSWORD

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20

# ── Security ────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Email (optional) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@vapttracker.com
FROM_NAME=eKavach

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
