# ============================================
# eKavach VAPT Tracker - Environment Config
# ============================================
# Copy this file to backend/.env and fill in values.
# NEVER commit .env to version control.
# ============================================

# Server
NODE_ENV=production
PORT=5000
API_VERSION=v1

# Database
# If MongoDB auth is enabled:
MONGO_URI=mongodb://root:YOUR_MONGO_PASSWORD@127.0.0.1:27017/vapt_tracker?authSource=admin
# MONGO_URI=mongodb://127.0.0.1:27017/vapt_tracker
MONGO_DB_NAME=vapt_tracker
DB_MAX_POOL=10
DB_MIN_POOL=1
DB_MAX_RETRIES=10
DB_RETRY_DELAY_MS=3000
DB_HEALTH_INTERVAL_MS=30000

# JWT - Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET
REFRESH_TOKEN_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_SECRET
COOKIE_SECRET=CHANGE_THIS_TO_A_COOKIE_SECRET
JWT_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Storage
STORAGE_ROOT=
MAX_FILE_SIZE=52428800

# CORS
FRONTEND_URL=http://localhost
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1

# Super Admin (only used on first run when DB is empty)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=CHANGE_SUPER_ADMIN_PASSWORD

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20

# Security
BCRYPT_ROUNDS=12

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@example.com
FROM_NAME=eKavach

# Logging
LOG_LEVEL=info
